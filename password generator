#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>

int main() {
    int length;
    char include_numbers[10];
    char include_special[10];

    // Character pools definitions
    char letters[] = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ";
    char digits[] = "0123456789";
    char special_chars[] = "!\"#$%&'()*+,-./:;<=>?@[\\]^_`{|}~";
    char character_pool[200] = ""; 
    srand(time(NULL));

    printf("--- Password Generator Project ---\n");
    printf("Enter the length of the password: ");
    if (scanf("%d", &length) != 1 || length < 1) {
        printf("Invalid length. Please enter a number greater than 0.\n");
        return 1;
    }

    printf("Are numeric characters/numbers required in the password? (yes/no): ");
    scanf("%s", include_numbers);

    printf("Are special characters required in the password? (yes/no): ");
    scanf("%s", include_special);
    strcat(character_pool, letters);

    if (strcmp(include_numbers, "yes") == 0) {
        strcat(character_pool, digits);
    }
    if (strcmp(include_special, "yes") == 0) {
        strcat(character_pool, special_chars);
    }
    char *password = malloc((length + 1) * sizeof(char));
    if (password == NULL) {
        printf("Memory allocation failed.\n");
        return 1;
    }

    int letters_len = strlen(letters);
    password[0] = letters[rand() % letters_len];

    int pool_len = strlen(character_pool);
    for (int i = 1; i < length; i++) {
        password[i] = character_pool[rand() % pool_len];
    }

    password[length] = '\0';
    printf("\nGenerated Password: %s\n", password);
    free(password);

    return 0;
}
